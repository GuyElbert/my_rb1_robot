<?xml version="1.0" ?>
<robot name="rb1_robot">
    <!-- Specify Gazebo color for the base_link -->
    <gazebo reference="base_link">
        <visual>
            <material> <!-- Black -->
                <!-- TODO: Define parameters for a black chassis -->
                <ambient>0.1 0.1 0.1 1.0</ambient>
                <diffuse>0.1 0.1 0.1 1.0</diffuse>
                <specular>0.0 0.0 0.0 1.0</specular>
                <emissive>0.0 0.0 0.0 1.0</emissive>
            </material>
        </visual>
    </gazebo>

    <!-- Gazebo friction and material properties for left_wheel -->
    <gazebo reference="left_wheel">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <!-- TODO: Define mu (first friction coefficient) -->
                        <mu>0.5</mu>
                        <!-- TODO: Define mu2 (second friction coefficient) -->
                        <mu2>0.5</mu2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <!-- Gazebo friction and material properties for right_wheel -->
    <gazebo reference="right_wheel">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <!-- TODO: Define mu (first friction coefficient) -->
                        <mu>0.5</mu>
                        <!-- TODO: Define mu2 (second friction coefficient) -->
                        <mu2>0.5</mu2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <!-- Gazebo friction and material properties for front_caster -->
    <gazebo reference="front_caster">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <!-- TODO: Define mu (first friction coefficient) -->
                        <mu>0.2</mu>
                        <!-- TODO: Define mu2 (second friction coefficient) -->
                        <mu2>0.2</mu2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <!-- Gazebo friction and material properties for back_caster -->
    <gazebo reference="back_caster">
        <collision>
            <surface>
                <friction>
                    <ode>
                        <!-- TODO: Define mu (first friction coefficient) -->
                        <mu>0.2</mu>
                        <!-- TODO: Define mu2 (second friction coefficient) -->
                        <mu2>0.2</mu2>
                    </ode>
                </friction>
            </surface>
        </collision>
    </gazebo>

    <!-- Define materials for visualization -->
    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>

    <material name="gray">
        <color rgba="0.40 0.40 0.40 1"/>
    </material>

    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <!-- Base footprint link -->
    <link name="base_footprint">
    </link>

    <!-- Joint connecting base_link and base_footprint -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_plate_joint" type="fixed">
        <!-- TO DO: Define axis (if needed) -->
        <!-- TO DO: Define origin -->
        <origin rpy="0 0 0" xyz="0 0 -0.15" />
        <!-- TO DO: Define parent -->
        <parent link="base_link" />
        <!-- TO DO: Define child -->
        <child link="base_footprint" />
    </joint>

    <!-- Base link -->
    <link name="base_link">
        <!-- TO DO: Add visual tag -->
        <visual>
            <geometry>
                <cylinder radius=".25" length=".3" />
            </geometry>
        </visual>
        <!-- TO DO: Add collision tag -->
        <collision>
            <geometry>
                <cylinder radius=".25" length=".3" />
            </geometry>
        </collision>
        <!-- TO DO: Add inertial tag -->
        <inertial>
            <mass value="20" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx=".4625" ixy="0" ixz="0" iyy=".4625" iyz="0" izz=".625" />
        </inertial>
    </link>

    <!-- Left wheel link -->
    <link name="left_wheel">
        <!-- TO DO: Add visual tag -->
        <visual>
            <origin rpy="1.5707 0 0" xyz="0 0 0" />
            <geometry>
                <cylinder radius=".025" length=".03" />
            </geometry>
        </visual>
        <!-- TO DO: Add collision tag -->
        <collision>
            <origin rpy="1.5707 0 0" xyz="0 0 0" />
            <geometry>
                <cylinder radius=".025" length=".03" />
            </geometry>
        </collision>
        <!-- TO DO: Add inertial tag -->
        <inertial>
            <mass value="1.25" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="0.00029" ixy="0" ixz="0" iyy="0.00029" iyz="0" izz="0.00039" />
        </inertial>
    </link>

    <!-- Joint connecting base_link and left_wheel -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_left_wheel_joint" type="continuous">
        <!-- TO DO: Define axis (if needed) -->
        <axis rpy="0 0 0" xyz="0 1 0" />
        <!-- TO DO: Define origin -->
        <origin rpy="0 0 0" xyz="0.0 -0.2 -0.15" />
        <!-- TO DO: Define parent -->
        <parent link="base_link" />
        <!-- TO DO: Define child -->
        <child link ="left_wheel" />
    </joint>

    <!-- Right wheel link -->
    <link name="right_wheel">
        <!-- TO DO: Add visual tag -->
        <visual>
            <origin rpy="1.5707 0 0" xyz="0 0 0" />
            <geometry>
                <cylinder radius=".025" length=".03" />
            </geometry>
        </visual>
        <!-- TO DO: Add collision tag -->
        <collision>
            <origin rpy="1.5707 0 0" xyz="0 0 0" />
            <geometry>
                <cylinder radius=".25" length=".3" />
            </geometry>
        </collision>
        <!-- TO DO: Add inertial tag -->
        <inertial>
            <mass value="1.25" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="0.00029" ixy="0" ixz="0" iyy="0.00029" iyz="0" izz="0.00039" />
        </inertial>
    </link>

    <!-- Joint connecting base_link and right_wheel -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_right_wheel_joint" type="continuous">
        <!-- TO DO: Define axis (if needed) -->
        <axis rpy="0 0 0" xyz="0 1 0" />
        <!-- TO DO: Define origin -->
        <origin rpy="0 0 0" xyz="0.0 0.2 -0.15" />
        <!-- TO DO: Define parent -->
        <parent link="base_link" />
        <!-- TO DO: Define child -->
        <child link ="right_wheel" />
    </joint>

    <!-- Front caster -->
    <link name="front_caster">
        <!-- TO DO: Add visual tag -->
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <sphere radius=".025" />
            </geometry>
        </visual>
        <!-- TO DO: Add collision tag -->
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <sphere radius=".025" />
            </geometry>
        </collision>
        <!-- TO DO: Add inertial tag -->
        <inertial>
            <mass value="1.25" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="0.0003125" ixy="0" ixz="0" iyy="0.0003125" iyz="0" izz="0.0003125"/>
        </inertial>
    </link>

    <!-- Joint connecting base_link and front_caster -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_front_caster_joint" type="continuous">
        <!-- TO DO: Define axis (if needed) -->
        <axis rpy="1 1 1" xyz="1 1 0" />
        <!-- TO DO: Define origin -->
        <origin rpy="0 0 0" xyz="0.1 0.0 -0.15" />
        <!-- TO DO: Define parent -->
        <parent link="base_link" />
        <!-- TO DO: Define child -->
        <child link ="front_caster" />
        <joint_properties friction="0.0" />
    </joint>

    <!-- Back caster -->
    <link name="back_caster">
        <!-- TO DO: Add visual tag -->
        <visual>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <sphere radius=".025" />
            </geometry>
        </visual>
        <!-- TO DO: Add collision tag -->
        <collision>
            <origin rpy="0 0 0" xyz="0 0 0" />
            <geometry>
                <sphere radius=".025" />
            </geometry>
        </collision>
        <!-- TO DO: Add inertial tag -->
        <inertial>
            <mass value="1.25" />
            <origin xyz="0 0 0" rpy="0 0 0" />
            <inertia ixx="0.0003125" ixy="0" ixz="0" iyy="0.0003125" iyz="0" izz="0.0003125"/>
        </inertial>
    </link>

    <!-- Joint connecting base_link and back_caster -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_back_caster_joint" type="continuous">
        <!-- TO DO: Define axis (if needed) -->
        <axis rpy="1 1 1" xyz="1 1 0" />
        <!-- TO DO: Define origin -->
        <origin rpy="0 0 0" xyz="-0.1 0.0 -0.15" />
        <!-- TO DO: Define parent -->
        <parent link="base_link" />
        <!-- TO DO: Define child -->
        <child link ="back_caster" />
        <joint_properties friction="0.0" />
    </joint>

    <!-- Link representing the front laser scanner -->
    <!--For this robot, the laser is not visible, so we won't define a body for it. -->
    <link name="front_laser">
    </link>

    <!-- Joint connecting base_link and front_laser -->
    <!-- TO DO: Set correct joint type -->
    <joint name="base_link_front_laser_joint" type="fixed">
        <!-- TO DO: Define axis (if needed) -->
        <!-- TO DO: Define origin -->
        <origin rpy="3.14159 0 0" xyz="0.25 0.0 0.075" />
        <!-- TO DO: Define parent -->
        <parent link="base_link" />
        <!-- TO DO: Define child -->
        <child link ="front_laser" />
    </joint>

    <!-- Differential Drive Plugin -->
    <gazebo>
        <plugin
            filename="libgz-sim-diff-drive-system.so"
            name="gz::sim::systems::DiffDrive">
            <left_joint>base_link_left_wheel_joint</left_joint>
            <right_joint>base_link_right_wheel_joint</right_joint>
            <wheel_separation>.4</wheel_separation>
            <wheel_radius>0.025</wheel_radius>
            <odom_publish_frequency>20</odom_publish_frequency>
            <topic>cmd_vel</topic>
            <odom_topic>odom</odom_topic>
            <tf_topic>tf</tf_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_link</child_frame_id>
        </plugin>
    </gazebo>

    <!-- Laser Scanner Plugin -->
<gazebo>
    <plugin
      filename="libgz-sim-sensors-system"
      name="gz::sim::systems::Sensors">
      <!-- use ogre2 if ogre v2.x is installed, otherwise use ogre -->
      <render_engine>ogre2</render_engine>
    </plugin>
</gazebo>

    <gazebo reference="link_laser_scan">
        <sensor type="gpu_lidar" name="head_hokuyo_sensor">
            <pose relative_to='lidar_frame'>0 0 0 0 0 0</pose>
            <always_on>1</always_on>
            <visualize>true</visualize>
            <update_rate>20</update_rate>
            <topic>/laser/scan</topic>
            <ray>
                <scan>
                    <horizontal>
                        <samples>720</samples>
                        <resolution>1</resolution>
                        <min_angle>-1.570796</min_angle>
                        <max_angle>1.570796</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.20</min>
                    <max>10.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </ray>
        </sensor>
    </gazebo>

</robot>